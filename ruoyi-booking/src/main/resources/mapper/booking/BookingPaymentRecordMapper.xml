<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.booking.mapper.BookingPaymentRecordMapper">

    <resultMap type="BookingPaymentRecord" id="BookingPaymentRecordResult">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="transactionId" column="transaction_id"/>
        <result property="payMethod" column="pay_method"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status"/>
        <result property="requestData" column="request_data"/>
        <result property="responseData" column="response_data"/>
        <result property="callbackData" column="callback_data"/>
        <result property="payTime" column="pay_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectRecordVo">
        SELECT id, order_no, transaction_id, pay_method, amount, status,
               request_data, response_data, callback_data, pay_time, create_time
        FROM booking_payment_record
    </sql>

    <insert id="insertPaymentRecord" parameterType="BookingPaymentRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO booking_payment_record (
            order_no, transaction_id, pay_method, amount, status,
            request_data, response_data, callback_data, pay_time, create_time
        ) VALUES (
                     #{orderNo}, #{transactionId}, #{payMethod}, #{amount}, #{status},
                     #{requestData}, #{responseData}, #{callbackData}, #{payTime}, sysdate()
                 )
    </insert>

    <select id="selectRecordsByOrderNo" parameterType="String" resultMap="BookingPaymentRecordResult">
        <include refid="selectRecordVo"/>
        WHERE order_no = #{orderNo}
        ORDER BY create_time DESC
    </select>

    <select id="selectByTransactionId" parameterType="String" resultMap="BookingPaymentRecordResult">
        <include refid="selectRecordVo"/>
        WHERE transaction_id = #{transactionId}
    </select>

    <update id="updateRecordByTransactionId" parameterType="BookingPaymentRecord">
        UPDATE booking_payment_record
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="callbackData != null">callback_data = #{callbackData},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
        </set>
        WHERE transaction_id = #{transactionId}
    </update>

</mapper>