<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.booking.mapper.BookingOrderMapper">

    <resultMap type="BookingOrder" id="BookingOrderResult">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="bookingId" column="booking_id"/>
        <result property="bookingNo" column="booking_no"/>
        <result property="userId" column="user_id"/>
        <result property="deptId" column="dept_id"/>
        <result property="amount" column="amount"/>
        <result property="paidAmount" column="paid_amount"/>
        <result property="subject" column="subject"/>
        <result property="body" column="body"/>
        <result property="status" column="status"/>
        <result property="payMethod" column="pay_method"/>
        <result property="transactionId" column="transaction_id"/>
        <result property="expireTime" column="expire_time"/>
        <result property="payTime" column="pay_time"/>
        <result property="cancelTime" column="cancel_time"/>
        <result property="callbackData" column="callback_data"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectBookingOrderVo">
        select id, order_no, booking_id, booking_no, user_id, dept_id, amount, paid_amount,
               subject, body, status, pay_method, transaction_id, expire_time, pay_time,
               cancel_time, callback_data, create_time, update_time
        from payment_order
    </sql>

    <select id="selectBookingOrderList" parameterType="BookingOrder" resultMap="BookingOrderResult">
        <include refid="selectBookingOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND order_no = #{orderNo}
            </if>
            <if test="bookingNo != null and bookingNo != ''">
                AND booking_no = #{bookingNo}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="deptId != null">
                AND dept_id = #{deptId}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBookingOrderById" parameterType="Long" resultMap="BookingOrderResult">
        <include refid="selectBookingOrderVo"/>
        where id = #{id}
    </select>

    <select id="selectBookingOrderByNo" parameterType="String" resultMap="BookingOrderResult">
        <include refid="selectBookingOrderVo"/>
        where order_no = #{orderNo}
    </select>

    <select id="selectBookingOrderByBookingNo" parameterType="String" resultMap="BookingOrderResult">
        <include refid="selectBookingOrderVo"/>
        where booking_no = #{bookingNo}
    </select>

    <insert id="insertBookingOrder" parameterType="BookingOrder" useGeneratedKeys="true" keyProperty="id">
        insert into payment_order (
            order_no, booking_id, booking_no, user_id, dept_id,
            amount, paid_amount, subject, body, status,
            pay_method, transaction_id, expire_time, pay_time,
            cancel_time, callback_data, create_time, update_time
        ) values (
                     #{orderNo}, #{bookingId}, #{bookingNo}, #{userId}, #{deptId},
                     #{amount}, #{paidAmount}, #{subject}, #{body}, #{status},
                     #{payMethod}, #{transactionId}, #{expireTime}, #{payTime},
                     #{cancelTime}, #{callbackData}, sysdate(), sysdate()
                 )
    </insert>

    <update id="updateBookingOrder" parameterType="BookingOrder">
        update payment_order
        <set>
            <if test="bookingId != null">booking_id = #{bookingId},</if>
            <if test="bookingNo != null">booking_no = #{bookingNo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="payMethod != null">pay_method = #{payMethod},</if>
            <if test="transactionId != null">transaction_id = #{transactionId},</if>
            <if test="paidAmount != null">paid_amount = #{paidAmount},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="cancelTime != null">cancel_time = #{cancelTime},</if>
            <if test="callbackData != null">callback_data = #{callbackData},</if>
            update_time = sysdate()
        </set>
        where order_no = #{orderNo}
    </update>

    <update id="updateStatusByOrderNo">
        update payment_order
        set status = #{status},
        <if test="payTime != null">pay_time = #{payTime},</if>
        update_time = sysdate()
        where order_no = #{orderNo}
    </update>

    <delete id="deleteBookingOrderByIds" parameterType="String">
        delete from payment_order where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>